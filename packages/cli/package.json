{
  "name": "@koda/opero-cli",
  "version": "0.2.2",
  "description": "CLI for the Opero API",
  "type": "module",
  "bin": {
    "opero": "./bin/run.js"
  },
  "files": [
    "agent-skills",
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node ./bin/dev.js",
    "pack:standalone": "node ../../scripts/pack-standalone.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@oclif/core": "^4.11.11",
    "@oclif/plugin-autocomplete": "^3.2.52",
    "@oclif/table": "^0.5.9",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oclif": "^4.23.21",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "oclif": {
    "bin": "opero",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "theme": {
      "bin": "cyan",
      "command": "cyan",
      "commandSummary": "gray",
      "dollarSign": "gray",
      "flag": "yellow",
      "flagDefaultValue": "gray",
      "flagOptions": "gray",
      "flagRequired": "yellowBright",
      "sectionDescription": "gray",
      "sectionHeader": "cyan",
      "topic": "cyan",
      "version": "gray"
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Manage Opero API authentication."
      },
      "config": {
        "description": "Manage Opero CLI configuration."
      },
      "contractors": {
        "description": "Manage Opero contractors."
      },
      "currencies": {
        "description": "Read supported currencies."
      },
      "custom-modules": {
        "description": "Manage custom data modules and module schema drafts."
      },
      "custom-modules schema-drafts": {
        "description": "Manage custom module schema drafts."
      },
      "custom-objects": {
        "description": "Manage custom data objects and object schema drafts."
      },
      "custom-objects schema-drafts": {
        "description": "Manage custom object schema drafts."
      },
      "custom-records": {
        "description": "Manage custom data records."
      },
      "custom-scripts": {
        "description": "Manage custom scripts."
      },
      "dictionaries": {
        "description": "Read dictionaries and entries."
      },
      "entity-attachments": {
        "description": "Manage file attachments on entities."
      },
      "entity-comments": {
        "description": "Manage comments on entities."
      },
      "files": {
        "description": "Upload, inspect, and download files."
      },
      "request": {
        "description": "Run raw authenticated Opero API requests."
      },
      "rules": {
        "description": "Manage automation rules and rule execution history."
      },
      "service-catalog": {
        "description": "Manage service catalog items."
      },
      "skills": {
        "description": "List and install Opero agent skills."
      },
      "skills install": {
        "description": "Install bundled Opero agent skills."
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
