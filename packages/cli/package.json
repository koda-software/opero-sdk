{
  "name": "@koda/opero-cli",
  "version": "0.1.0",
  "description": "CLI for the Opero external API",
  "type": "module",
  "bin": {
    "opero": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node ./bin/dev.js",
    "pack:standalone": "node ../../scripts/pack-standalone.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@oclif/core": "^4.11.11",
    "@oclif/table": "^0.5.9",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oclif": "^4.23.21",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "oclif": {
    "bin": "opero",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Manage Opero API authentication."
      },
      "config": {
        "description": "Manage Opero CLI configuration."
      },
      "contractors": {
        "description": "Read Opero contractors."
      },
      "currencies": {
        "description": "Read supported currencies."
      },
      "custom-modules": {
        "description": "Read custom data modules."
      },
      "custom-objects": {
        "description": "Read custom data objects."
      },
      "custom-records": {
        "description": "Read custom data records."
      },
      "dictionaries": {
        "description": "Read dictionaries and entries."
      },
      "entity-attachments": {
        "description": "Manage file attachments on entities."
      },
      "files": {
        "description": "Upload, inspect, and download files."
      },
      "request": {
        "description": "Run raw authenticated Opero API requests."
      },
      "service-catalog": {
        "description": "Manage service catalog items."
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
