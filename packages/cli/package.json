{
  "name": "@koda/opero-cli",
  "version": "0.4.0",
  "description": "CLI for the Opero API",
  "type": "module",
  "bin": {
    "opero": "./bin/run.js"
  },
  "files": [
    "agent-skills",
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', {recursive: true, force: true})\" && tsc -p tsconfig.json",
    "dev": "node ./bin/dev.js",
    "pack:standalone": "node ../../scripts/pack-standalone.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@oclif/core": "^4.11.11",
    "@oclif/plugin-autocomplete": "^3.2.52",
    "@oclif/table": "^0.5.9",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oclif": "^4.23.21",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "oclif": {
    "bin": "opero",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-autocomplete"
    ],
    "theme": {
      "bin": "cyan",
      "command": "cyan",
      "commandSummary": "gray",
      "dollarSign": "gray",
      "flag": "yellow",
      "flagDefaultValue": "gray",
      "flagOptions": "gray",
      "flagRequired": "yellowBright",
      "sectionDescription": "gray",
      "sectionHeader": "cyan",
      "topic": "cyan",
      "version": "gray"
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Manage Opero API authentication."
      },
      "config": {
        "description": "Manage Opero CLI configuration."
      },
      "contractors": {
        "description": "Manage Opero contractors."
      },
      "currencies": {
        "description": "Read supported currencies."
      },
      "custom-modules": {
        "description": "Manage custom data modules."
      },
      "custom-objects": {
        "description": "Manage custom data objects and object schema drafts."
      },
      "custom-objects field-types": {
        "description": "Read dynamic object field type schemas."
      },
      "custom-objects schema-drafts": {
        "description": "Manage custom object schema drafts."
      },
      "custom-records": {
        "description": "Manage custom data records."
      },
      "custom-scripts": {
        "description": "Manage custom scripts."
      },
      "dictionaries": {
        "description": "Manage dictionaries and entries."
      },
      "dictionaries entries": {
        "description": "Manage dictionary entries."
      },
      "entity-attachments": {
        "description": "Manage file attachments on entities."
      },
      "entity-comments": {
        "description": "Manage comments on entities."
      },
      "files": {
        "description": "Upload, inspect, and download files."
      },
      "queries": {
        "description": "Manage saved SQL queries."
      },
      "request": {
        "description": "Run raw authenticated Opero API requests."
      },
      "rules": {
        "description": "Manage automation rules and rule execution history."
      },
      "service-catalog": {
        "description": "Manage service catalog items."
      },
      "view-layouts": {
        "description": "Manage View Layouts and runtime layout data."
      },
      "view-layouts assignments": {
        "description": "Manage View Layout assignments."
      },
      "view-layouts draft": {
        "description": "Manage View Layout drafts."
      },
      "view-layouts draft staged-field-definitions": {
        "description": "Read staged custom-field draft options."
      },
      "view-layouts runtime": {
        "description": "Use View Layout runtime endpoints."
      },
      "view-layouts runtime dynamic-object": {
        "description": "Use dynamic-object runtime View Layout endpoints."
      },
      "view-layouts runtime dynamic-object records": {
        "description": "Create and update dynamic records through View Layouts."
      },
      "view-layouts runtime dynamic-object relation-tables": {
        "description": "Use relation-table runtime View Layout endpoints."
      },
      "view-layouts versions": {
        "description": "Read and restore View Layout versions."
      },
      "workflow-templates": {
        "description": "List workflow templates and create workflows from templates."
      },
      "workflows": {
        "description": "Manage workflow definitions, drafts, publications, runtime instances, and tasks."
      },
      "workflows assignment-candidates": {
        "description": "Look up valid workflow assignment candidates."
      },
      "workflows draft": {
        "description": "Read and save workflow drafts."
      },
      "workflows publications": {
        "description": "Read workflow publications and restore drafts."
      },
      "workflows runtime": {
        "description": "Read and execute workflow runtime instances."
      },
      "workflows tasks": {
        "description": "Read and manage workflow tasks."
      },
      "skills": {
        "description": "List and install Opero agent skills."
      },
      "skills install": {
        "description": "Install bundled Opero agent skills."
      }
    }
  },
  "engines": {
    "node": ">=18"
  }
}
